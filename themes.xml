<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PulseVPN" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/green_mid</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:textColorPrimary">@color/text</item>
        <item name="android:textColorSecondary">@color/text2</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="GreenButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/btn_green</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="rippleColor">@color/green_dark</item>
    </style>

    <style name="ProtoButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:background">@drawable/btn_proto_inactive</item>
        <item name="android:textColor">@color/text2</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="strokeColor">@color/transparent</item>
    </style>

    <style name="ProtoButton.Active">
        <item name="android:background">@drawable/btn_proto_active</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="CardStyle" parent="">
        <item name="android:background">@drawable/card_bg</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="LabelSmall">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text2</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="ValueGreen">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/green</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
