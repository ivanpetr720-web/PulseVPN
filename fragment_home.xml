<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/btn_green"
                android:text="P"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Pulse"
                android:textColor="@color/text"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <!-- VPN text in green done via compound -->
            <TextView
                android:id="@+id/btn_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/card_bg"
                android:text="⚙"
                android:textColor="@color/text2"
                android:textSize="18sp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- STATUS -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="● НЕ ПОДКЛЮЧЁН"
            android:textColor="@color/text2"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

        <!-- CONNECT BUTTON -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <!-- Ring 1 -->
            <View
                android:id="@+id/ring1"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="@drawable/connect_btn_normal"
                android:alpha="0.15"/>

            <!-- Ring 2 -->
            <View
                android:id="@+id/ring2"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:background="@drawable/connect_btn_normal"
                android:alpha="0.2"/>

            <!-- Main button -->
            <TextView
                android:id="@+id/btn_connect"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:background="@drawable/connect_btn_normal"
                android:text="⏻&#10;CONNECT"
                android:textColor="@color/text2"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:lineSpacingExtra="6dp"/>
        </FrameLayout>

        <!-- TIMER -->
        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:gravity="center"
            android:fontFamily="monospace"
            android:visibility="gone"/>

        <!-- STATS ROW -->
        <LinearLayout
            android:id="@+id/stats_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⬇  DOWNLOAD"
                    android:textColor="@color/text2"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/tv_dl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 MB/s"
                    android:textColor="@color/green"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <View android:layout_width="10dp" android:layout_height="1dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⬆  UPLOAD"
                    android:textColor="@color/text2"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/tv_ul"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 MB/s"
                    android:textColor="@color/green"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- PROTOCOL TOGGLE -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/card_bg"
            android:orientation="horizontal"
            android:padding="4dp"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_wg"
                style="@style/ProtoButton.Active"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WireGuard"/>

            <Button
                android:id="@+id/btn_ovpn"
                style="@style/ProtoButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OpenVPN"
                android:layout_marginStart="4dp"/>

            <Button
                android:id="@+id/btn_auto_proto"
                style="@style/ProtoButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- IP CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌐"
                android:textSize="26sp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ВАШ IP"
                    android:textColor="@color/text2"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/tv_ip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Определяется…"
                    android:textColor="@color/green"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp"/>
                <TextView
                    android:id="@+id/tv_ip_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Загрузка…"
                    android:textColor="@color/text2"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_ip_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌐"
                android:textSize="30sp"/>
        </LinearLayout>

        <!-- SELECTED SERVER QUICK VIEW -->
        <LinearLayout
            android:id="@+id/selected_server_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/smart_card_bg"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/tv_selected_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textSize="30sp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ SMART SELECT"
                    android:textColor="@color/green"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/tv_selected_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Лучший сервер"
                    android:textColor="@color/text"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tv_selected_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Авто · WireGuard"
                    android:textColor="@color/text2"
                    android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_selected_ping"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 ms"
                android:textColor="@color/green"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
